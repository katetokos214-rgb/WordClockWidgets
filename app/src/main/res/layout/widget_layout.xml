<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:padding="0dp">

    <FrameLayout
        android:id="@+id/widget_border"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_border">

        <!-- Transparent content container for positioning -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="5dp">

            <!-- Hour text wrapper for independent positioning -->
            <FrameLayout
                android:id="@+id/hour_wrapper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center">
                <TextView
                    android:id="@+id/hour_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:autoSizeTextType="none"
                    android:text="Четыре"
                    android:textColor="@android:color/black"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- Minute text wrapper for independent positioning -->
            <FrameLayout
                android:id="@+id/minute_wrapper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center">
                <TextView
                    android:id="@+id/minute_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:autoSizeTextType="none"
                    android:text="Сорок три"
                    android:textColor="@android:color/black"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- Day/Night wrapper for independent positioning -->
            <FrameLayout
                android:id="@+id/day_night_wrapper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center">
                <TextView
                    android:id="@+id/day_night_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:autoSizeTextType="none"
                    android:text="дня"
                    android:textColor="@android:color/holo_red_dark"
                    android:textSize="18sp" />
            </FrameLayout>

            <!-- Date wrapper for independent positioning -->
            <FrameLayout
                android:id="@+id/date_wrapper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone">
                <TextView
                    android:id="@+id/date_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:autoSizeTextType="none"
                    android:text="Тринадцатое марта"
                    android:textColor="@android:color/black"
                    android:textSize="14sp" />
            </FrameLayout>

            <!-- Day of Week wrapper for independent positioning -->
            <FrameLayout
                android:id="@+id/day_of_week_wrapper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone">
                <TextView
                    android:id="@+id/day_of_week_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="8sp"
                    android:autoSizeMaxTextSize="96sp"
                    android:autoSizeStepGranularity="1sp"
                    android:text="Понедельник"
                    android:textColor="@android:color/black"
                    android:textSize="16sp" />
            </FrameLayout>

        </FrameLayout>

    </FrameLayout>

</FrameLayout>